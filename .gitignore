# OS / editor
.DS_Store
*.swp
*~

# Obsidian (the vault is kept OUTSIDE this repo; ignore defensively)
.obsidian/

# Secrets / local environment
*.local
.env
.env.*
*.key
*.pem
secrets/

# Rendered runtime configs (contain real keys/identities — never commit)
server.json
config.json
/out/
/state/

# On-node bootstrap/updater local-only artifacts (per-node identity + rendered configs).
# These live under /var/lib/mycelium and /opt/mycelium on a real node; the patterns below are a
# defensive net in case anything is ever generated INSIDE the repo working tree during testing.
# NEVER commit per-node identity, secrets, params, or rendered configs.
params.json
identity.json
identities.json
config.candidate.json
config.staged.json
config.lastgood.json
config.staged.ack
cert.sha256.txt
awg.port
# Node-local reachability monitor config (ADR-0019): real anchors are operator state, never
# committed. The repo ships only control/reach.config.example.json (allowlisted public-DNS anchors).
reach.config.json
# If the canonical checkout is ever cloned under the repo (prefer /opt/mycelium outside it):
/opt/
/var/

# Stray nested Obsidian vault if one is ever (re)created inside the repo
/mycelium/
Добро пожаловать.md

# Internal audit / review reports — kept locally, never published
docs/audits/
# Operator's real node AS-diversity inventory (real IPs/AS/providers) — local only; the repo ships
# only the template + abstracted rationale (docs/runbooks/node-as-inventory.md).
docs/runbooks/node-as-inventory.local.md

# Release artifacts (`make dist` output) — built on demand / in CI, never committed
/dist/

# Stray scratch / tool output — never commit
.checkout.txt
/.scan_tmp/
/.scan-tmp.*/
*.out.txt
# Local research reports (deep-research outputs; evidence backing public ADRs) — kept local, never published
docs/research/
