#
# Mycelium Phase 0 — Ansible inventory (EXAMPLE).
# Author: mindicator & silicon bags quartet
#
# Copy to "inventory.ini" (which is gitignored) and fill in the real node reachability address.
# The node must be a fresh Debian/Ubuntu VPS on a public IP.
#
#   cp inventory.ini.example inventory.ini
#   $EDITOR inventory.ini
#
# Replace NODE_PUBLIC_IP with the node's public IPv4 (or IPv6, or a DNS name that resolves to it).
# 'ansible_user=root' assumes a vanilla fresh VPS; switch to a sudo-capable user + become if your
# provider ships a non-root default account.

[mycelium_nodes]
NODE_PUBLIC_IP ansible_user=root
