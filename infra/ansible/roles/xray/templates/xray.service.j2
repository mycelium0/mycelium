# Mycelium Phase 0 — hardened systemd unit for the Xray data plane.
# Author: mindicator & silicon bags quartet
#
# Rendered by the xray role. Runs as an unprivileged system user. CAP_NET_BIND_SERVICE is the
# only ambient capability granted, so the process can bind :{{ listen_port }} without root.
[Unit]
Description=Mycelium Xray data plane (VLESS+XTLS-Vision+REALITY)
Documentation=https://github.com/XTLS/Xray-core
After=network-online.target nss-lookup.target
Wants=network-online.target

[Service]
Type=simple
User={{ xray_run_user }}
Group={{ xray_run_group }}

ExecStart={{ xray_bin_path }} run -config {{ xray_config_path }}
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5s
LimitNOFILE=1048576

# --- Privilege containment -------------------------------------------------
# Allow binding the privileged listen port without running as root.
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true

# --- Filesystem protection -------------------------------------------------
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
# Config and geo assets live here and are read-only to the service; nothing is written at runtime.
ReadOnlyPaths={{ xray_etc_dir }}
ReadWritePaths=

# --- Kernel / device / namespace isolation --------------------------------
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectControlGroups=true
ProtectClock=true
ProtectHostname=true
ProtectProc=invisible
ProcSubset=pid
PrivateDevices=true
DevicePolicy=closed
RestrictNamespaces=true
RestrictRealtime=true
RestrictSUIDSGID=true
LockPersonality=true
MemoryDenyWriteExecute=true
RemoveIPC=true
KeyringMode=private
UMask=0077

# --- Network / syscall surface --------------------------------------------
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
SystemCallArchitectures=native
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources @obsolete

[Install]
WantedBy=multi-user.target
